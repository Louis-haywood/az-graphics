# ── Discord Application ──────────────────────────────────────────
DISCORD_CLIENT_ID=        # Application > OAuth2 > Client ID
DISCORD_CLIENT_SECRET=    # Application > OAuth2 > Client Secret
DISCORD_BOT_TOKEN=        # Application > Bot > Token

# ── Your Server ──────────────────────────────────────────────────
DISCORD_GUILD_ID=         # Right-click server icon > Copy Server ID
DISCORD_STAFF_ROLE_ID=    # Right-click your staff role > Copy Role ID
DISCORD_ORDER_CATEGORY_ID= # Right-click the category for order channels > Copy ID
DISCORD_ORDERS_CHANNEL_ID= # Right-click the channel the webhook posts to > Copy ID

# ── URLs ─────────────────────────────────────────────────────────
# Must match exactly what you add in Discord Developer Portal > OAuth2 > Redirects
REDIRECT_URI=https://YOUR_VPS_DOMAIN/auth/callback
# Your Hostinger site URL (no trailing slash)
FRONTEND_URL=https://YOUR_SITE_DOMAIN

# ── Server ───────────────────────────────────────────────────────
PORT=3000
